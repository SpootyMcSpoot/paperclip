{
  "name": "@stapleai/plugin-fake-sandbox",
  "version": "0.1.0",
  "description": "First-party deterministic fake sandbox provider plugin for Staple environments",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "staplePlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js"
  },
  "scripts": {
    "prebuild": "node ../../../scripts/ensure-plugin-build-deps.mjs",
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "pnpm --filter @stapleai/plugin-sdk build && tsc --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@stapleai/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}

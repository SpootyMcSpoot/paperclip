# Paperclip Server Configuration

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/paperclip

# Server
PORT=3100
HOST=0.0.0.0
SERVE_UI=false

# Memory Service (Qdrant)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=your-api-key
# QDRANT_API_KEY_PATH=/var/run/secrets/qdrant/api-key

# LLM Observability (Langfuse)
# LANGFUSE_HOST=localhost
# LANGFUSE_PORT=3000
# LANGFUSE_BASE_URL=http://localhost:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY_PATH=/var/run/secrets/langfuse/public-key
# LANGFUSE_SECRET_KEY_PATH=/var/run/secrets/langfuse/secret-key

# MCP (Model Context Protocol)
# Simple format (multiple servers): MCP_SERVERS=github:http://...,kubernetes:http://...
# Or individual servers:
# MCP_SERVER_GITHUB_URL=http://localhost:8080
# MCP_SERVER_KUBERNETES_URL=http://localhost:8081
# MCP_SERVER_POSTGRES_URL=http://localhost:8082
# MCP_SERVER_PROMETHEUS_URL=http://localhost:8083

# AI Firewall
# AI_FIREWALL_URL=http://localhost:8000
# AI_FIREWALL_API_KEY=your-api-key
# AI_FIREWALL_API_KEY_PATH=/var/run/secrets/ai-firewall/api-key
# AI_FIREWALL_ENABLED=true

# Code Graph
# CODE_GRAPH_URL=http://localhost:8097
